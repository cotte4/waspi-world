# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_CHECKOUT_CURRENCY=usd
STRIPE_ARS_PER_USD=1300

# Resend
RESEND_API_KEY=

# YouTube Data API v3 (for Jukebox search)
YOUTUBE_API_KEY=

# App
# Use your public/LAN URL when testing with other devices or friends.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Voice / WebRTC
# STUN fallback for local/dev. Production should use /api/voice/ice + TURN envs below.
NEXT_PUBLIC_VOICE_ICE_SERVERS={"iceServers":[{"urls":"stun:stun.l.google.com:19302"},{"urls":"stun:stun1.l.google.com:19302"}]}
NEXT_PUBLIC_PEERJS_DEBUG=1
NEXT_PUBLIC_PEERJS_HOST=
NEXT_PUBLIC_PEERJS_PORT=443
NEXT_PUBLIC_PEERJS_PATH=/peerjs
NEXT_PUBLIC_PEERJS_SECURE=true
NEXT_PUBLIC_PEERJS_KEY=

# Voice / TURN (server-only)
# Option A: Metered TURN (recommended for $0 dev/testing)
# METERED_TURN_DOMAIN=<appname>.metered.live
# METERED_TURN_SECRET_KEY=<secret key from Metered dashboard>
METERED_TURN_DOMAIN=
METERED_TURN_SECRET_KEY=
VOICE_TURN_TTL_SECONDS=3600

# Optional TURN URLs override. If empty and Metered is configured, defaults to:
# stun:stun.relay.metered.ca:80
# turn:global.relay.metered.ca:80
# turn:global.relay.metered.ca:80?transport=tcp
# turn:global.relay.metered.ca:443
# turns:global.relay.metered.ca:443?transport=tcp
VOICE_TURN_URLS=

# Option B: self-hosted coturn using REST auth shared secret.
VOICE_TURN_SECRET=
